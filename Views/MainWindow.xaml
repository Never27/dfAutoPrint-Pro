<Window x:Class="PdfAutoPrint.Pro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PdfAutoPrint.Pro.ViewModels"
        xmlns:cv="clr-namespace:PdfAutoPrint.Pro.Converters"
        Title="PdfAutoPrint Pro" Height="700" Width="960"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <cv:StatusToColorConverter x:Key="StatusToColor"/>
        <cv:FileSizeConverter x:Key="FileSizeConv"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}" Padding="20,12" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PdfAutoPrint Pro" FontSize="18" FontWeight="500"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="16,0"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="全部启动" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding StartAllCommand}" Margin="0,0,8,0"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                    <Button Content="全部停止" Style="{StaticResource DangerButton}" 
                            Command="{Binding StopAllCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TabControl -->
        <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="16,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Padding="{TemplateBinding Padding}" Cursor="Hand"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,3"
                                        Background="Transparent">
                                    <ContentPresenter Content="{TemplateBinding Header}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" 
                                                Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: 仪表盘 -->
            <TabItem Header="仪表盘">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- 打印机卡片 -->
                        <TextBlock Text="虚拟打印机" FontSize="15" FontWeight="500" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding Printers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                                            Padding="16" Margin="0,0,0,8"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 状态指示 -->
                                            <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center"
                                                     Fill="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                            <!-- 信息 -->
                                            <StackPanel Grid.Column="1" Margin="12,0">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="500"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="状态: " FontSize="12" 
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding Status}" FontSize="12" 
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text=" | 任务: " FontSize="12" 
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0"/>
                                                    <TextBlock Text="{Binding JobCount}" FontSize="12" 
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text=" | 输出: " FontSize="12" 
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0"/>
                                                    <TextBlock Text="{Binding OutputDir}" FontSize="12" 
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- 操作 -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="配置" Style="{StaticResource SecondaryButton}" 
                                                        Command="{Binding DataContext.EditPrinterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                                <Button Content="打开目录" Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding DataContext.OpenOutputFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ 创建虚拟打印机" Style="{StaticResource PrimaryButton}" 
                                Command="{Binding CreatePrinterCommand}" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: 打印机管理 -->
            <TabItem Header="打印机管理">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="系统打印机" FontSize="15" FontWeight="500" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="刷新列表" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshSystemPrintersCommand}" Margin="0,0,8,0"/>
                            <Button Content="重启打印服务" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RestartSpoolerCommand}"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding SystemPrinters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                                            Padding="14" Margin="0,0,0,6"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="500"/>
                                                    <TextBlock Text=" (默认)" FontSize="12" 
                                                               Foreground="{StaticResource SuccessBrush}" 
                                                               Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}" Margin="4,0,0,0"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="驱动: " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding DriverName}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text=" | 端口: " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0"/>
                                                    <TextBlock Text="{Binding PortName}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="设为默认" Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding DataContext.SetDefaultPrinterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Name}"
                                                    Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: 日志 -->
            <TabItem Header="日志">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="打开日志目录" Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenLogFolderCommand}"/>
                        <TextBlock Text=" (最近500条)" FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" 
                             Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1" Padding="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" BorderBrush="{StaticResource BorderBrush}" 
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Time, StringFormat=yyyy-MM-dd HH:mm:ss}" 
                                                   FontSize="11" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Level}" FontSize="11" 
                                                   FontFamily="Consolas" FontWeight="500"
                                                   Foreground="{Binding Level, Converter={StaticResource StatusToColor}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Tab 4: 任务历史 -->
            <TabItem Header="任务历史">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="清空历史" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearHistoryCommand}" HorizontalAlignment="Right" Margin="0,0,0,8"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding RecentJobs}"
                              Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="时间" Width="130" DisplayMemberBinding="{Binding StartTime, StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                                <GridViewColumn Header="打印机" Width="140" DisplayMemberBinding="{Binding PrinterName}"/>
                                <GridViewColumn Header="作业名" Width="160" DisplayMemberBinding="{Binding JobName}"/>
                                <GridViewColumn Header="输出文件" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OutputFile}" TextTrimming="CharacterEllipsis" 
                                                       ToolTip="{Binding OutputFile}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="大小" Width="70" DisplayMemberBinding="{Binding FileSize, Converter={StaticResource FileSizeConv}}"/>
                                <GridViewColumn Header="状态" Width="60" DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="耗时" Width="70" DisplayMemberBinding="{Binding DurationMs, StringFormat={}{0}ms}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
