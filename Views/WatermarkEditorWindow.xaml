<Window x:Class="PdfAutoPrint.Pro.Views.WatermarkEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑水印" Height="500" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/app.ico"
        Background="{StaticResource BgBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource FormLabel}" Text="水印类型"/>
            <TextBlock x:Name="txtType" FontSize="14" FontWeight="500"/>

            <!-- 文本水印 -->
            <StackPanel x:Name="pnlText" Visibility="Visible">
                <TextBlock Style="{StaticResource FormLabel}" Text="文字内容（支持占位符）"/>
                <TextBox x:Name="txtContent" Style="{StaticResource FormInput}"/>

                <TextBlock Style="{StaticResource FormLabel}" Text="字体"/>
                <TextBox x:Name="txtFontFamily" Style="{StaticResource FormInput}" Text="SimSun"/>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormLabel}" Text="字号" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtFontSize" Width="60" Style="{StaticResource FormInput}" Text="48"/>
                    </StackPanel>
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Style="{StaticResource FormLabel}" Text="颜色 (#RRGGBB)" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtFontColor" Width="100" Style="{StaticResource FormInput}" Text="#FF0000"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox x:Name="chkBold" Content="粗体" FontSize="13" Margin="0,0,16,0"/>
                    <CheckBox x:Name="chkItalic" Content="斜体" FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <!-- 图片水印 -->
            <StackPanel x:Name="pnlImage" Visibility="Collapsed">
                <TextBlock Style="{StaticResource FormLabel}" Text="图片路径"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtImagePath" Style="{StaticResource FormInput}" Width="300" IsReadOnly="True"/>
                    <Button x:Name="btnBrowseImage" Content="浏览" 
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="缩放 (%):" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtImageScale" Width="60" Style="{StaticResource FormInput}" 
                             Text="100" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- 位置 -->
            <TextBlock Style="{StaticResource FormLabel}" Text="位置" FontSize="14" FontWeight="500" Margin="0,12,0,2"/>
            <ComboBox x:Name="cmbAnchor" Style="{StaticResource FormCombo}">
                <ComboBoxItem Content="左上" Tag="TopLeft"/>
                <ComboBoxItem Content="中上" Tag="TopCenter"/>
                <ComboBoxItem Content="右上" Tag="TopRight"/>
                <ComboBoxItem Content="左中" Tag="MiddleLeft"/>
                <ComboBoxItem Content="居中" Tag="Center"/>
                <ComboBoxItem Content="右中" Tag="MiddleRight"/>
                <ComboBoxItem Content="左下" Tag="BottomLeft"/>
                <ComboBoxItem Content="中下" Tag="BottomCenter"/>
                <ComboBoxItem Content="右下" Tag="BottomRight"/>
                <ComboBoxItem Content="绝对坐标" Tag="Absolute"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="水平偏移" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="txtOffsetX" Width="60" Style="{StaticResource FormInput}" Text="0"/>
                        <ComboBox x:Name="cmbUnit" Width="70" Margin="4,0,0,0" Style="{StaticResource FormCombo}" SelectedIndex="0">
                            <ComboBoxItem Content="pt"/>
                            <ComboBoxItem Content="mm"/>
                            <ComboBoxItem Content="inch"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="垂直偏移" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="txtOffsetY" Width="60" Style="{StaticResource FormInput}" Text="0"/>
                </StackPanel>
            </StackPanel>

            <!-- 其他 -->
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="透明度" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="txtOpacity" Width="60" Style="{StaticResource FormInput}" Text="0.3"/>
                </StackPanel>
                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="旋转角度" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="txtRotation" Width="60" Style="{StaticResource FormInput}" Text="0"/>
                </StackPanel>
            </StackPanel>

            <!-- 页面范围 -->
            <CheckBox x:Name="chkAllPages" Content="所有页面" FontSize="13" Margin="0,12,0,0" IsChecked="True"/>
            <StackPanel x:Name="pnlPageRange" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="跳过前" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSkipFirst" Width="40" Style="{StaticResource FormInput}" Text="0" Margin="4,0,0,0"/>
                    <TextBlock Text="页，跳过后" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBox x:Name="txtSkipLast" Width="40" Style="{StaticResource FormInput}" Text="0" Margin="4,0,0,0"/>
                    <TextBlock Text="页" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource CardBrush}" Padding="16,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" 
                        Click="OnCancel" Margin="0,0,8,0"/>
                <Button Content="保存" Style="{StaticResource PrimaryButton}" 
                        Click="OnSave"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
